rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 1. Therapist data — only the therapist themselves
    match /users/{userId} {
      allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == 'manuel@alphatek.ai');
      allow write: if isOwner(userId);
      
      match /patients/{patientId} {
        allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == 'manuel@alphatek.ai');
        allow write: if isOwner(userId);
        
        match /screenings/{screeningId} {
          allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == 'manuel@alphatek.ai');
          allow write: if isOwner(userId);
        }
      }
      match /protocols/{protocolId} {
        allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == 'manuel@alphatek.ai');
        allow write: if isOwner(userId);
      }
      match /custom_tests/{testId} {
        allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == 'manuel@alphatek.ai');
        allow write: if isOwner(userId);
      }
      match /saved_comments/{commentId} {
        allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == 'manuel@alphatek.ai');
        allow write: if isOwner(userId);
      }
    }

    // 2. Session codes — publicly readable (needed for code+email verification before auth)
    //    Only the owning therapist can create/update
    match /session_codes/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.therapistUid;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.therapistUid;
    }

    // 3. Patient data — only the patient themselves (by anonymous Firebase UID)
    //    Completely isolated from therapist paths
    match /patients/{patientUid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == patientUid;
    }

    // 4. Admin override — global read for admin email
    match /{document=**} {
      allow read: if request.auth != null && request.auth.token.email == 'manuel@alphatek.ai';
    }
  }
}
